<%- include('../partials/header') %>

<h1><%= title %></h1>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="flash error"><%= error %></div>
<% } %>

<div class="note">
  Al guardar se generan <code>movieSnapshot</code> y <code>genreSnapshot</code> desde la película seleccionada.
</div>

<form method="post" action="<%= action %>">
  <% if (method === 'PUT') { %>
    <input type="hidden" name="_method" value="PUT">
  <% } %>

  <div class="form-grid">
    <div class="form-group">
      <label>Cliente *</label>
      <select name="customerId" required>
        <option value="">— seleccionar —</option>
        <% customers.forEach(c => { %>
          <option value="<%= c._id %>" <%= activity.customerId == c._id ? 'selected' : '' %>>
            <%= c._id %> — <%= c.firstName %> <%= c.lastName %> (<%= c.email %>)
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label>Película *</label>
      <select name="movieId" id="movieId" required>
        <option value="">— seleccionar —</option>
        <% movies.forEach(m => { %>
          <option value="<%= m._id %>" <%= activity.movieId == m._id ? 'selected' : '' %>>
            <%= m._id %> — <%= m.title %> (<%= m.year %>)
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label>Género (snapshot)</label>
      <select name="genreId" id="genreId" data-selected="<%= activity.genreId ?? '' %>">
        <option value="">— automático (primer género de la película) —</option>
      </select>
    </div>

    <div class="form-group">
      <label>Tipo de actividad</label>
      <input type="text" name="activity" value="<%= activity.activity || '' %>" placeholder="WATCH, CLICK...">
    </div>

    <div class="form-group">
      <label>Fecha y hora</label>
      <input type="datetime-local" name="activityTime" value="<%= activity.activityTime ? new Date(activity.activityTime).toISOString().slice(0,16) : '' %>">
    </div>

    <div class="form-group">
      <label>App</label>
      <input type="text" name="app" value="<%= activity.app || '' %>">
    </div>

    <div class="form-group">
      <label>Sistema operativo</label>
      <input type="text" name="os" value="<%= activity.os || '' %>">
    </div>

    <div class="form-group">
      <label>Dispositivo (nombre)</label>
      <input type="text" name="deviceName" value="<%= activity.device?.name || '' %>">
    </div>

    <div class="form-group">
      <label>Dispositivo (tipo)</label>
      <input type="text" name="deviceType" value="<%= activity.device?.type || '' %>">
    </div>
  </div>

  <script type="application/json" id="movies-json"><%- JSON.stringify(movies.map(m => ({ _id: m._id, genres: m.genres }))) %></script>

  <div class="actions" style="margin-top:1.5rem;">
    <button type="submit" class="btn">Guardar</button>
    <a href="<%= activity._id ? '/activities/' + encodeURIComponent(activity._id) : '/activities' %>" class="btn secondary">Cancelar</a>
  </div>
</form>

<%- include('../partials/footer') %>
